{
	"version": 3,
	"routes": [
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/checkin/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/checkin/[sessionId]"
		},
		{
			"src": "^/dashboard/?(?:/__data.json)?$",
			"dest": "/dashboard"
		},
		{
			"src": "^/members/?(?:/__data.json)?$",
			"dest": "/members"
		},
		{
			"src": "^/members/new/?(?:/__data.json)?$",
			"dest": "/members/new"
		},
		{
			"src": "^/scan/?(?:/__data.json)?$",
			"dest": "/scan"
		},
		{
			"src": "^/sessions/?(?:/__data.json)?$",
			"dest": "/sessions"
		},
		{
			"src": "^/sessions/new/?(?:/__data.json)?$",
			"dest": "/sessions/new"
		},
		{
			"src": "^/sessions/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/sessions/[id]"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}